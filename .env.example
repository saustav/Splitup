# Supabase — https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: force the OAuth callback origin (must match Supabase Redirect URLs exactly)
# Local dev:
# EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=http://localhost:8081
# Production (set automatically in GitHub Actions deploy):
# EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=https://splitup.mantradigital.com.np

# Optional: web push (also set notification.vapidPublicKey in app.json)
# EXPO_PUBLIC_NOTIFICATION_VAPID_PUBLIC_KEY=your-vapid-public-key
