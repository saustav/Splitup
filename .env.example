# Supabase — https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Khalti — https://khalti.com/merchant
EXPO_PUBLIC_KHALTI_PUBLIC_KEY=your-khalti-public-key

# eSewa — https://developer.esewa.com.np
EXPO_PUBLIC_ESEWA_MERCHANT_CODE=your-merchant-code
EXPO_PUBLIC_ESEWA_ENV=development

# Optional: web push (also set notification.vapidPublicKey in app.json)
# EXPO_PUBLIC_NOTIFICATION_VAPID_PUBLIC_KEY=your-vapid-public-key
