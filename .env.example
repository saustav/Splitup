# Supabase — https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: force the OAuth callback origin (must match Supabase Redirect URLs exactly)
# Local dev:
# EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=http://localhost:8081
# Production (set automatically in GitHub Actions deploy):
# EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=https://splitup.mantradigital.com.np

# Khalti — https://khalti.com/merchant
EXPO_PUBLIC_KHALTI_PUBLIC_KEY=your-khalti-public-key

# eSewa — https://developer.esewa.com.np
EXPO_PUBLIC_ESEWA_MERCHANT_CODE=your-merchant-code
EXPO_PUBLIC_ESEWA_ENV=development

# Optional: web push (also set notification.vapidPublicKey in app.json)
# EXPO_PUBLIC_NOTIFICATION_VAPID_PUBLIC_KEY=your-vapid-public-key

# WhatsApp bot (Supabase Edge Function secrets — not used in the Expo app)
# WHATSAPP_VERIFY_TOKEN=your-meta-webhook-verify-token
# WHATSAPP_ACCESS_TOKEN=your-meta-permanent-token
# WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
